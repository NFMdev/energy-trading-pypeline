# ============================================================
# Energy Trading Pipeline - Local development configuration
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

APP_ENV=local

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=energy_pipeline
DATABASE_USER=energy_user
DATABASE_PASSWORD=energy_password

# SQLAlchemy connection URL.
# Keep this in sync with the individual database settings above.
DATABASE_URL=postgresql+psycopg://energy_user:energy_password@localhost:5432/energy_pipeline

# ------------------------------------------------------------
# Redpanda / Kafka-compatible broker
# ------------------------------------------------------------

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_RAW_TOPIC=energy.market.raw.v1
KAFKA_CONSUMER_GROUP=energy-market-ingestion-v1

# ------------------------------------------------------------
# Synthetic event generator
# ------------------------------------------------------------

GENERATOR_MARKET_AREAS=DK1,DK2,DE,SE3,NO2